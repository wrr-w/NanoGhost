# =============================================================================
# NanoGhost 环境变量配置
# =============================================================================
# 优先级：实例 .env > 项目根 .env
# 启动时 --instance-dir / -I 指定实例目录，自动加载 <实例目录>/.env
# 以下列出所有代码中实际读取的变量，按功能分类
# =============================================================================


# =============================================================================
# 1. LLM 配置（必需）
# =============================================================================
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=


# =============================================================================
# 2. Embedding 配置（内置模型无需配置，设为空即可）
# =============================================================================
# EMBED_MODEL 为空 → 使用内置 fastembed (BAAI/bge-small-zh-v1.5)
# EMBED_MODEL 有值（如 text-embedding-3-small）→ 调远程 API
# 远程时可指定独立 endpoint/key，否则复用 LLM 的
EMBED_MODEL=
# EMBED_BASE_URL=
# EMBED_API_KEY=
# EMBED_LOCAL_MODEL=BAAI/bge-small-zh-v1.5


# =============================================================================
# 3. 飞书通道（AGENT_MODE=feishu 时必需）
# =============================================================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERBOSE=false


# =============================================================================
# 4. Agent 运行模式与后端
# =============================================================================
# 运行模式：cli（交互式命令行）| feishu（飞书 WebSocket 机器人）
AGENT_MODE=cli

# Agent 调用的后端 API 地址（如 Capture 服务）
AGENT_BASE_URL=http://127.0.0.1:8000

# SQLite 数据库路径（默认 <实例目录>/data/agent_data.db）
# AGENT_DB_PATH=


# =============================================================================
# 5. 多实例隔离
# =============================================================================
# 启动时通过 -I / --instance-dir 指定，或设置此变量
# INSTANCE_DIR=

# 实例命名空间（用于记忆隔离，默认取实例目录名）
# AGENT_NAMESPACE=

# 工作目录（Agent 执行 shell 命令的 cwd，默认 <实例目录>/work）
# AGENT_WORKDIR=

# 自定义 prompts 目录（默认 <实例目录>/prompts）
# AGENT_PROMPTS_DIR=


# =============================================================================
# 6. 技能 / MCP 配置
# =============================================================================
# 技能发现目录（默认 ~/.agents/skills）
# AGENTS_SKILLS_DIR=~/.agents/skills

# 全局 MCP / config.yaml 路径（默认 ~/.nanoghost/config.yaml）
# NANOGHOST_GLOBAL_CONFIG=~/.nanoghost/config.yaml

# 实例根目录（nanoghost instance list 扫描此目录，默认 ~/.nanoghost/instances）
# NANOGHOST_INSTANCES_ROOT=~/.nanoghost/instances

# run.py 路径（Gateway 启动子进程时使用，默认自动查找）
# NANOGHOST_RUNPY=


# =============================================================================
# 7. 网络 / 代理
# =============================================================================
# 绕过系统代理（Windows 常有 Clash 等设为系统默认但未启动，
# 导致 Python 网络请求连不上。设 * 表示所有连接直连。）
NO_PROXY=*
